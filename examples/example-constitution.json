  "architecture": {
    "patterns": [
      {
        "name": "Microservices",
        "description": "Decompose applications into small, independently deployable services",
        "use_case": "New backend applications with clear domain boundaries",
        "reference": "https://microservices.io/"
      },
      {
        "name": "Event-Driven Architecture",
        "description": "Services communicate via asynchronous events",
        "use_case": "Decoupled integrations, audit trails, eventual consistency",
        "reference": "https://docs.aws.amazon.com/eventbridge/"
      },
      {
        "name": "Clean Architecture",
        "description": "Layered architecture with dependency inversion",
        "use_case": "Complex domain logic requiring testability",
        "reference": "https://blog.cleancoder.com/uncle-bob/2012/08/13/the-clean-architecture.html"
      }
    ],
    "principles": [
      {
        "name": "API-First",
        "statement": "Define APIs before implementation using OpenAPI or similar specification",
        "rationale": "Enables parallel development, clear contracts, better documentation",
        "examples": ["OpenAPI spec reviewed before coding", "Generated clients from specs"]
      },
      {
        "name": "Twelve-Factor App",
        "statement": "Follow twelve-factor principles for cloud-native applications",
        "rationale": "Portability, scalability, operational simplicity",
        "examples": ["Config in environment", "Stateless processes", "Port binding"]
      },
      {
        "name": "Fail Fast",
        "statement": "Validate inputs early and fail with clear errors",
        "rationale": "Easier debugging, better user experience, security",
        "examples": ["Input validation at API boundary", "Schema validation on messages"]
      }
    ],
    "api_standards": {
      "style": "REST with OpenAPI 3.1 specification",
      "versioning": "URL path versioning (e.g., /v1/resources)",
      "authentication": "OAuth 2.0 with JWT tokens",
      "documentation": "OpenAPI spec required, hosted on internal API portal",
      "rate_limiting": "Required for all public APIs, configurable per-client"
    },
    "data_standards": {
      "naming": "snake_case for database columns, camelCase for JSON",
      "retention": "Define retention policy for all PII; default 7 years for financial data",
      "privacy": "GDPR and CCPA compliant; data classification required",
      "encryption": "AES-256 for data at rest, TLS 1.3 for transit"
    }
  },
  "file_organization": {
    "specs": {
      "root_path": "specs/",
      "roadmap_path": "specs/roadmap.json",
      "constitution_path": "specs/constitution.json",
      "active_path": "specs/active/",
      "backlog_path": "specs/backlog/",
      "completed_path": "specs/completed/",
      "archived_path": "specs/archived/",
      "feature_files": {
        "mrd_file": "mrd.json",
        "prd_file": "prd.json",
        "evaluation_file": "evaluation.json"
      }
    },
    "docs": {
      "root_path": "docs/",
      "design_path": "docs/design/",
      "versioned_design_pattern": "docs/design/{version}/",
      "feature_design_pattern": "docs/design/{feature}/",
      "adr_path": "docs/adr/",
      "runbooks_path": "docs/runbooks/"
    },
    "spec_to_doc_mapping": {
      "strategy": "feature",
      "feature_field": "metadata.feature",
      "version_field": "overview.target_release",
      "doc_file_extension": ".md",
      "include_spec_type_prefix": false,
      "generate_index": true
    },
    "naming_conventions": {
      "version_format": "^v\\d+\\.\\d+\\.\\d+$",
      "version_example": "v1.2.3",
      "feature_format": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$",
      "feature_example": "user-authentication",
      "spec_file_format": "{type}.json",
      "spec_file_example": "mrd.json"
    }
  },
  "quality": {
    "testing": {
      "unit_test_coverage": "80%",
      "integration_test_required": true,
      "e2e_test_required": true,
      "performance_test_required": true,
      "security_test_required": true,
      "test_frameworks": ["Go testing", "Jest", "Playwright", "k6"]
    },
    "code_review": {
      "required_approvals": 2,
      "require_owner_approval": true,
      "automated_checks": ["lint", "test", "security-scan", "coverage"],
      "max_pr_size": 500
    },
    "metrics": [
      {
        "name": "Deployment Frequency",
        "description": "How often code is deployed to production",
        "target": "Daily",
        "measurement": "CI/CD pipeline metrics"
      },
      {
        "name": "Lead Time for Changes",
        "description": "Time from commit to production",
        "target": "< 24 hours",
        "measurement": "CI/CD pipeline metrics"
      },
      {
        "name": "Change Failure Rate",
        "description": "Percentage of deployments causing failure",
        "target": "< 5%",
        "measurement": "Incident tracking system"
      },
      {
        "name": "Mean Time to Recovery",
        "description": "Time to restore service after failure",
        "target": "< 1 hour",
        "measurement": "Incident tracking system"
      }
    ]
  },
  "security": {
    "authentication": {
      "methods": ["OAuth 2.0", "OIDC", "API Keys (internal only)"],
      "mfa_required": true,
      "session_timeout": "8 hours",
      "password_policy": "Minimum 12 characters, complexity requirements, no reuse of last 10"
    },
    "authorization": {
      "model": "RBAC with Cedar policy language",
      "default_deny": true,
      "audit_required": true
    },
    "data_protection": {
      "encryption_at_rest": true,
      "encryption_in_transit": true,
      "pii_handling": "Classify all PII, encrypt, log access, support deletion requests",
      "secret_management": "AWS Secrets Manager or HashiCorp Vault; no secrets in code or config files"
    },
    "compliance": ["SOC 2 Type II", "GDPR", "CCPA"],
    "vulnerability_scanning": {
      "dependency_scanning": true,
      "container_scanning": true,
      "sast_required": true,
      "dast_required": true,
      "max_critical_vulnerabilities": 0
    }
  },
  "documentation": {
    "readme_required": true,
    "api_doc_required": true,
    "architecture_doc_required": true,
    "runbook_required": true,
    "changelog_required": true,
    "format": "Markdown with MkDocs for published documentation"
  },
  "process": {
    "branching_strategy": "Trunk-based development with short-lived feature branches",
    "commit_convention": "Conventional Commits v1.0.0",
    "release_process": "Semantic versioning with automated releases from main branch",
    "incident_response": "PagerDuty escalation, postmortem required for SEV1/SEV2",
    "on_call_required": true
  }
}
